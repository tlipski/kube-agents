apiVersion: kubeagents.x-k8s.io/v1alpha1
kind: DevTeamAgent
metadata:
  name: devteam-agent-${TARGET_CLUSTER_NAME}-${TARGET_CLUSTER_LOCATION}-${TARGET_NAMESPACE}
  namespace: kubeagents-system
spec:
  harness:
    clusterName: "${TARGET_CLUSTER_NAME}"
    location: "${TARGET_CLUSTER_LOCATION}"
    namespace: "${TARGET_NAMESPACE}"
    hermes:
      apiServerSecretRef:
        name: "platform-agent-secrets"
        key: "API_SERVER_KEY"
  deployment:
    image: "${DEVTEAM_AGENT_IMAGE}"
    tag: "latest"
  security:
    serviceAccountName: "kubeagents-devteam-agent"
    workloadIdentity:
      gcp:
        gsaName: "kubeagents-devteam-gsa"
        projectId: "${PROJECT_ID}"
