# Use the official Google Cloud SDK slim image as base
FROM google/cloud-sdk:slim

# Install common utilities
RUN apt-get update && apt-get install -y \
    unzip \
    curl \
    openssl \
    jq \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install kubectl and GKE auth plugin
RUN apt-get update && apt-get install -y \
    google-cloud-cli-gke-gcloud-auth-plugin \
    kubectl \
    && rm -rf /var/lib/apt/lists/*

# Install Terraform
ARG TERRAFORM_VERSION="1.8.5"
RUN curl -sSLf -o /tmp/terraform.zip "https://releases.hashicorp.com/terraform/${TERRAFORM_VERSION}/terraform_${TERRAFORM_VERSION}_linux_amd64.zip" \
    && unzip /tmp/terraform.zip -d /usr/local/bin \
    && rm /tmp/terraform.zip

# Install Helm
ARG HELM_VERSION="v3.15.2"
RUN curl -sSLf -o /tmp/helm.tar.gz "https://get.helm.sh/helm-${HELM_VERSION}-linux-amd64.tar.gz" \
    && tar -xzf /tmp/helm.tar.gz -C /tmp \
    && mv /tmp/linux-amd64/helm /usr/local/bin/helm \
    && rm -rf /tmp/helm.tar.gz /tmp/linux-amd64

# Set up workspace
WORKDIR /app

# Copy the necessary directories for deployment
# We copy k8s-operator which contains deploy/terraform, deploy/helm, and scripts.
COPY k8s-operator/ /app/k8s-operator/
RUN ls -la /app/k8s-operator/deploy/terraform/

# Copy the entrypoint script
COPY k8s-operator/deploy/docker/iac_entrypoint.sh /usr/local/bin/iac-entrypoint
RUN chmod +x /usr/local/bin/iac-entrypoint

ENTRYPOINT ["/usr/local/bin/iac-entrypoint"]
