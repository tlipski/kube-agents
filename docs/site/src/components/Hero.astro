---
// Overrides Starlight's default Hero.astro. Two changes vs. upstream:
//   1. Image width/height come from the source ImageMetadata (respects
//      native aspect ratio). Upstream hardcodes 400×400 which crushes
//      non-square banners.
//   2. Removes the desktop two-column grid so the layout stays
//      centered/stacked at all breakpoints (image above title/tagline).
//      Visual tuning done via theme.css so it stays in one place.
import { Image } from 'astro:assets';

// Inlined bits from Starlight — its `constants` and
// `user-components/LinkButton.astro` aren't documented export
// subpaths, so we can't import them cleanly. Link buttons are
// rendered as raw <a> with the same `sl-link-button {variant}`
// classes Starlight uses, so styling in theme.css still applies.
const PAGE_TITLE_ID = '_top';

const { data } = Astro.locals.starlightRoute.entry;
const { title = data.title, tagline, image, actions = [] } = data.hero || {};

let darkImage: ImageMetadata | undefined;
let lightImage: ImageMetadata | undefined;
let rawHtml: string | undefined;
if (image) {
  if ('file' in image) {
    darkImage = image.file;
  } else if ('dark' in image) {
    darkImage = image.dark;
    lightImage = image.light;
  } else {
    rawHtml = image.html;
  }
}

// Cap the rendered width so a 1024-wide source doesn't blow out the
// hero column. Height is derived from source aspect ratio.
const MAX_W = 540;
const imgFor = (src: ImageMetadata | undefined) =>
  src
    ? {
        w: Math.min(src.width, MAX_W),
        h: Math.round(Math.min(src.width, MAX_W) * (src.height / src.width)),
      }
    : { w: 0, h: 0 };
const darkDims = imgFor(darkImage);
const lightDims = imgFor(lightImage);

// Icons we render in hero CTAs. Inline SVG paths kept small to avoid
// pulling in Starlight's Icon component (its module isn't a public
// export subpath). `right-arrow` accompanies text CTAs; `github` is
// used icon-only via the `minimal` variant.
const ICON_PATHS: Record<string, string> = {
  'right-arrow':
    'M17.92 11.62a1.001 1.001 0 0 0-.21-.33l-5-5a1.003 1.003 0 1 0-1.42 1.42l3.3 3.29H7a1 1 0 0 0 0 2h7.59l-3.3 3.29a1.002 1.002 0 0 0 .325 1.639 1 1 0 0 0 1.095-.219l5-5a1 1 0 0 0 .21-.33 1 1 0 0 0 0-.76Z',
  github:
    'M12 .3a12 12 0 0 0-3.8 23.38c.6.12.83-.26.83-.57L9 21.07c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.83 1.24 1.83 1.24 1.08 1.83 2.81 1.3 3.5 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.1-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.28-1.55 3.29-1.23 3.29-1.23.64 1.66.24 2.88.12 3.18a4.65 4.65 0 0 1 1.23 3.22c0 4.61-2.8 5.63-5.48 5.92.42.36.81 1.1.81 2.22l-.01 3.29c0 .31.2.69.82.57A12 12 0 0 0 12 .3Z',
};
---

<div class="hero">
  {
    darkImage && (
      <Image
        src={darkImage}
        alt={image?.alt || ''}
        width={darkDims.w}
        height={darkDims.h}
        loading="eager"
        decoding="async"
        class:list={{ 'light:sl-hidden': Boolean(lightImage) }}
      />
    )
  }
  {
    lightImage && (
      <Image
        src={lightImage}
        alt={image?.alt || ''}
        width={lightDims.w}
        height={lightDims.h}
        loading="eager"
        decoding="async"
        class="dark:sl-hidden"
      />
    )
  }
  {rawHtml && <div class="hero-html sl-flex" set:html={rawHtml} />}
  <div class="sl-flex stack">
    <div class="sl-flex copy">
      <h1 id={PAGE_TITLE_ID} data-page-title set:html={title} />
      {tagline && <div class="tagline" set:html={tagline} />}
    </div>
    {
      actions.length > 0 && (
        <div class="sl-flex actions">
          {actions.map(({ attrs: { class: className, ...attrs } = {}, icon, link: href, text, variant = 'primary' }) => {
            const iconName = typeof icon === 'string' ? icon : icon?.name;
            const iconPath = iconName ? ICON_PATHS[iconName] : undefined;
            const isIconOnly = variant === 'minimal' && Boolean(iconPath);
            return (
              <a
                href={href}
                aria-label={isIconOnly ? text : undefined}
                class:list={['sl-link-button', 'not-content', variant, className, isIconOnly && 'icon-only']}
                {...attrs}
              >
                {isIconOnly ? (
                  <span class="sr-only">{text}</span>
                ) : (
                  text
                )}
                {iconPath && (
                  <svg
                    aria-hidden="true"
                    width={isIconOnly ? 24 : 18}
                    height={isIconOnly ? 24 : 18}
                    viewBox="0 0 24 24"
                    fill="currentColor"
                  >
                    <path d={iconPath} />
                  </svg>
                )}
              </a>
            );
          })}
        </div>
      )
    }
  </div>
</div>
